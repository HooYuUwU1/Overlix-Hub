-- [[ HÀM NHẬN NHIỆM VỤ THEO LEVEL ]] --
function GetQuest()
    local lvl = LP.Data.Level.Value
    if lvl >= 1 and lvl <= 10 then
        return {"BanditQuest1", "Bandit", CFrame.new(1059, 15, 1550), CFrame.new(1145, 17, 1630)}
    elseif lvl >= 10 and lvl <= 15 then
        return {"MonkeyQuest1", "Monkey", CFrame.new(-1598, 35, 153), CFrame.new(-1600, 40, 150)}
    -- Bạn có thể thêm các đảo khác vào đây theo cấu trúc: {TênQuest, TênQuái, TọaĐộNPC, TọaĐộQuái}
    end
end

-- [[ VÒNG LẶP CHÍNH - AUTO FARM ]] --
spawn(function()
    while task.wait() do
        if _G.AutoFarm then
            pcall(function()
                local questInfo = GetQuest()
                local questName = questInfo[1]
                local mobName = questInfo[2]
                local npcPos = questInfo[3]
                local mobPos = questInfo[4]

                -- Kiểm tra xem đã có nhiệm vụ chưa
                if not LP.PlayerGui.Main.Quest.Visible then
                    -- Di chuyển tới NPC nhận quest
                    SmoothTween(npcPos)
                    if (LP.Character.HumanoidRootPart.Position - npcPos.Position).Magnitude < 5 then
                        RS.Remotes.CommF_:InvokeServer("StartQuest", questName, 1)
                    end
                else
                    -- Đã có quest, đi tìm quái
                    local targetMob = nil
                    for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
                        if v.Name == mobName and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            targetMob = v
                            break
                        end
                    end

                    if targetMob then
                        -- Bay lên đầu quái để đánh
                        LP.Character.HumanoidRootPart.CFrame = targetMob.HumanoidRootPart.CFrame * CFrame.new(0, 11, 0)
                        
                        -- Tự động cầm vũ khí (Melee)
                        for _, tool in pairs(LP.Backpack:GetChildren()) do
                            if tool:IsA("Tool") and (tool.ToolTip == "Melee" or tool.ToolTip == "Sword") then
                                LP.Character.Humanoid:EquipTool(tool)
                            end
                        end
                    else
                        -- Đợi quái hồi sinh hoặc di chuyển tới bãi quái
                        SmoothTween(mobPos)
                    end
                end
            end)
        end
    end
end)

